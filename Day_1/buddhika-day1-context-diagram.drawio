        <mxCell id="title" value="LearnLanka — C4 System Context Diagram (Level 1)" style="text;html=1;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="560" height="30" as="geometry" />
        </mxCell>

        <!-- ===== ACTORS (People) ===== -->
        <mxCell id="student" value="Student&#10;[Person]&#10;&#10;O/L &amp; A/L student finding and booking tutors" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#08427B;strokeColor=#073B6F;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="50" height="100" as="geometry" />
        </mxCell>
        <mxCell id="tutor" value="Tutor&#10;[Person]&#10;&#10;Publishes slots, teaches, gets paid" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#08427B;strokeColor=#073B6F;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="50" height="100" as="geometry" />
        </mxCell>
        <mxCell id="admin" value="Operations Admin&#10;[Person]&#10;&#10;Vets tutors, runs payouts, handles disputes &amp; PDPA" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#08427B;strokeColor=#073B6F;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="80" y="580" width="50" height="100" as="geometry" />
        </mxCell>

        <!-- ===== SYSTEM IN SCOPE ===== -->
        <mxCell id="platform" value="LearnLanka Platform&#10;[Software System — IN SCOPE]&#10;&#10;Tutor search &amp; booking, payments orchestration,&#10;commission &amp; payouts, ratings, PDPA consent/deletion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0B4884;fontColor=#ffffff;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="430" y="360" width="300" height="140" as="geometry" />
