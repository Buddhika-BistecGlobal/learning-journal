        <!-- ===== RELATIONSHIPS: actors -> platform ===== -->
        <mxCell id="r1" value="Searches &amp; books sessions, rates tutor [HTTPS]" style="endArrow=block;html=1;fontSize=10;fontColor=#333333;rounded=0;strokeColor=#707070;" edge="1" parent="1" source="student" target="platform">
          <mxGeometry relative="1" as="geometry" />
