          <mxGeometry x="900" y="420" width="210" height="90" as="geometry" />
        </mxCell>
        <mxCell id="bank" value="Sampath Vishwa&#10;[External System]&#10;&#10;Bank for weekly tutor payouts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6C6C6C;fontColor=#ffffff;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="900" y="570" width="210" height="90" as="geometry" />
