        <mxCell id="r3" value="Vets tutors, runs payouts, handles PDPA [HTTPS]" style="endArrow=block;html=1;fontSize=10;fontColor=#333333;rounded=0;strokeColor=#707070;" edge="1" parent="1" source="admin" target="platform">
          <mxGeometry relative="1" as="geometry" />
