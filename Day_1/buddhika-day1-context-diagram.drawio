          <mxGeometry x="900" y="120" width="210" height="90" as="geometry" />
        </mxCell>
        <mxCell id="video" value="Daily.co / 100ms&#10;[External System]&#10;&#10;Third-party video calling for sessions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6C6C6C;fontColor=#ffffff;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="900" y="270" width="210" height="90" as="geometry" />
