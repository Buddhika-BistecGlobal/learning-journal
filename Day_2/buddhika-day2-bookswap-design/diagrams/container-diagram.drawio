<mxfile host="app.diagrams.net" agent="BookSwap Day2" version="24.0.0">
  <diagram name="C4-Container" id="bookswap-container">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1280" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="BookSwap — C4 Container Diagram (Level 2)" style="text;html=1;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="16" width="560" height="30" as="geometry" />
        </mxCell>

        <!-- Actor -->
        <mxCell id="member" value="Member&#10;[Person]&#10;Building neighbour" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fillColor=#08427B;strokeColor=#073B6F;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="60" y="300" width="50" height="100" as="geometry" />
        </mxCell>

        <!-- Containers (blue) -->
        <mxCell id="mobile" value="Mobile App&#10;[React Native]&#10;Member-facing UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1782C3;strokeColor=#0F5A8C;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="300" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="api" value="API Service&#10;[Node.js Express / Azure App Service]&#10;REST API, auth, orchestration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1782C3;strokeColor=#0F5A8C;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="300" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="bus" value="Message Queue&#10;[Azure Service Bus]&#10;Notifications, digest jobs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1782C3;strokeColor=#0F5A8C;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="290" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="worker" value="Worker&#10;[Node.js / Azure Functions]&#10;Drains queue, sends email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1782C3;strokeColor=#0F5A8C;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="450" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- Data stores (green) -->
        <mxCell id="sql" value="Database&#10;[Azure SQL]&#10;System of record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2D7D5A;strokeColor=#1E5F41;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="580" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="redis" value="Cache&#10;[Azure Cache for Redis]&#10;Hot read paths" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2D7D5A;strokeColor=#1E5F41;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="580" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="blob" value="Object Store&#10;[Azure Blob Storage]&#10;Book photos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2D7D5A;strokeColor=#1E5F41;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="910" y="580" width="190" height="90" as="geometry" />
        </mxCell>

        <!-- External (grey) -->
        <mxCell id="entra" value="Identity&#10;[Microsoft Entra External ID]&#10;Authn / issues JWT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C8C8C;strokeColor=#6C6C6C;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="220" y="110" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="email" value="Email&#10;[Azure Communication Services]&#10;Outbound digest / email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C8C8C;strokeColor=#6C6C6C;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="1230" y="450" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- SYNC edges (solid, dark) -->
        <mxCell id="e1" value="Uses [HTTPS]" style="endArrow=block;html=1;fontSize=10;strokeColor=#464646;strokeWidth=2;" edge="1" parent="1" source="member" target="mobile"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="Signs in, gets JWT [HTTPS/OIDC]" style="endArrow=block;html=1;fontSize=10;strokeColor=#464646;strokeWidth=2;" edge="1" parent="1" source="mobile" target="entra"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="API calls w/ Bearer JWT [HTTPS/JSON]" style="endArrow=block;html=1;fontSize=10;strokeColor=#464646;strokeWidth=2;" edge="1" parent="1" source="mobile" target="api"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="Validates JWT (JWKS) [HTTPS]" style="endArrow=block;html=1;fontSize=10;strokeColor=#464646;strokeWidth=2;" edge="1" parent="1" source="api" target="entra"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="Reads/writes [TDS/SQL]" style="endArrow=block;html=1;fontSize=10;strokeColor=#464646;strokeWidth=2;" edge="1" parent="1" source="api" target="sql"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="Caches hot reads [RESP]" style="endArrow=block;html=1;fontSize=10;strokeColor=#464646;strokeWidth=2;" edge="1" parent="1" source="api" target="redis"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="Stores/serves photos [HTTPS]" style="endArrow=block;html=1;fontSize=10;strokeColor=#464646;strokeWidth=2;" edge="1" parent="1" source="api" target="blob"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" value="Writes notifications [TDS]" style="endArrow=block;html=1;fontSize=10;strokeColor=#464646;strokeWidth=2;" edge="1" parent="1" source="worker" target="sql"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" value="Sends email [HTTPS]" style="endArrow=block;html=1;fontSize=10;strokeColor=#464646;strokeWidth=2;" edge="1" parent="1" source="worker" target="email"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ASYNC edges (dashed, orange) -->
        <mxCell id="a1" value="Enqueues jobs [AMQP]" style="endArrow=block;html=1;fontSize=10;dashed=1;strokeColor=#D06E14;fontColor=#D06E14;strokeWidth=2;" edge="1" parent="1" source="api" target="bus"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a2" value="Consumes messages [AMQP]" style="endArrow=block;html=1;fontSize=10;dashed=1;strokeColor=#D06E14;fontColor=#D06E14;strokeWidth=2;" edge="1" parent="1" source="worker" target="bus"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="Legend&#10;&#10;Blue = container we build/run   |   Green = managed data store   |   Grey = external service&#10;Solid arrow = synchronous call (request/response)&#10;Orange dashed arrow = asynchronous message (queue)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#FFFFFF;strokeColor=#999999;dashed=1;fontSize=11;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="220" y="700" width="470" height="150" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
