        <mxCell id="t" value="GreenChit — C4 Component Diagram: Claims API (Level 3)" style="text;html=1;align=center;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="380" y="14" width="640" height="30" as="geometry"/></mxCell>

